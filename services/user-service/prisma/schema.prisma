generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
    CUSTOMER
    ADMIN
}

model User {
    id              String      @id @default(uuid())

    name            String

    email           String      @unique

    password        String

    role            UserRole    @default(CUSTOMER)

    createdAt       DateTime    @default(now())

    updatedAt       DateTime    @updatedAt
}
{
    "compilerOptions": {
        "target": "ES2020",

        "module": "Node16",

        "moduleResolution": "node16",

        "moduleDetection": "legacy",

        "verbatimModuleSyntax": false,

        "strict": true,

        "esModuleInterop": true,

        "allowSyntheticDefaultImports": true,

        "skipLibCheck": true,

        "forceConsistentCasingInFileNames": true,

        "outDir": "dist",

        "rootDir": "."
    }
}